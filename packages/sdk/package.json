{
  "name": "@allen-saji/praxis",
  "version": "0.1.0",
  "description": "Security, simulation, and audit layer for AI agent spending on Sui. Simulate before you sign, explain after you spend.",
  "type": "module",
  "license": "MIT",
  "author": "Allen Saji <allensaji04@gmail.com> (https://allensaji.dev)",
  "homepage": "https://github.com/Allen-Saji/praxis#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Allen-Saji/praxis.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Allen-Saji/praxis/issues"
  },
  "keywords": [
    "sui",
    "ai-agents",
    "agent-security",
    "wallet-security",
    "transaction-simulation",
    "risk-engine",
    "walrus",
    "seal",
    "audit-trail",
    "web3"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mysten/sui": "^2.18.0",
    "@mysten/walrus": "^1.2.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
