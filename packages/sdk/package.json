{
  "name": "@praxis/sdk",
  "version": "0.1.0",
  "description": "Security, simulation, and audit layer for AI agent spending on Sui",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mysten/sui": "^2.18.0",
    "@mysten/walrus": "^1.2.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
