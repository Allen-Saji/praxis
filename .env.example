# Operator wallet that signs spends for the sample agents (Sui bech32 secret key).
# Never commit the real value.
PRAXIS_OPERATOR_KEY=suiprivkey...

# Optional Sui JSON-RPC override. Mysten retired public JSON-RPC on
# fullnode.testnet.sui.io (404s), so the SDK ships a working default; set this to
# swap providers without a code change. Must serve full event history
# (queryEvents) or the dashboard feed will read empty.
# SUI_RPC_URL=https://sui-testnet-endpoint.blockvision.org
# Browser-side (dapp-kit / wallet) override, inlined at build time:
# NEXT_PUBLIC_SUI_RPC_URL=https://sui-testnet-endpoint.blockvision.org

# Master secret for the local Seal stand-in. REQUIRED to seal or reveal sealed
# reasoning. Agents seal with this; the dashboard must reveal with the SAME
# value. Use a long random string. There is no default: sealing/revealing
# without it now throws (it used to silently fall back to a known dev secret).
PRAXIS_SEAL_SECRET=
