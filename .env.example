# Operator wallet that signs spends for the sample agents (Sui bech32 secret key).
# Never commit the real value.
PRAXIS_OPERATOR_KEY=suiprivkey...

# Master secret for the local Seal stand-in. REQUIRED to seal or reveal sealed
# reasoning. Agents seal with this; the dashboard must reveal with the SAME
# value. Use a long random string. There is no default: sealing/revealing
# without it now throws (it used to silently fall back to a known dev secret).
PRAXIS_SEAL_SECRET=
